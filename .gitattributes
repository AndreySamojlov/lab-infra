# Normalize all text files to LF in the repo.
# Working tree checks out with LF on any OS (incl. Windows).
# Keeps Linux containers happy and avoids CRLF churn on sync.

* text=auto eol=lf

# Explicit: shell scripts and YAML/JSON never CRLF.
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.env  text eol=lf
Caddyfile text eol=lf

# Binary-like — don't touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.gz   binary
